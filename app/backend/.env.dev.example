# M365 Agent SDK Settings (for Teams/Copilot integration)
# Create these via: ./scripts/setup-m365-bot.sh OR Azure Portal
M365_APP_ID=your-azure-ad-app-id
M365_APP_PASSWORD=your-azure-ad-app-secret
M365_APP_TENANT_ID=your-tenant-id-or-empty-for-multitenant
