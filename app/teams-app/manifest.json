{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.22/MicrosoftTeams.schema.json",
  "manifestVersion": "1.22",
  "version": "1.0.0",
  "id": "{{BOT_ID}}",
  "developer": {
    "name": "Contoso Banking",
    "websiteUrl": "https://contoso.com",
    "privacyUrl": "https://contoso.com/privacy",
    "termsOfUseUrl": "https://contoso.com/terms"
  },
  "name": {
    "short": "Banking Assistant",
    "full": "Contoso Banking Assistant"
  },
  "description": {
    "short": "AI-powered banking assistant for accounts, transactions, and payments",
    "full": "Get help with your bank accounts, view transaction history, make payments, and manage your finances through natural conversation. Powered by AI multi-agent orchestration. This assistant can help you check balances, search transactions, and process payments with approval workflows."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#0078D4",
  "bots": [
    {
      "botId": "{{BOT_ID}}",
      "scopes": [
        "personal",
        "team",
        "groupChat",
        "copilot"
      ],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "copilot"],
          "commands": [
            {
              "title": "balance",
              "description": "Check your account balance"
            },
            {
              "title": "transactions",
              "description": "View recent transactions"
            },
            {
              "title": "pay",
              "description": "Make a payment or transfer"
            },
            {
              "title": "cards",
              "description": "View your credit cards"
            },
            {
              "title": "help",
              "description": "Get help with available commands"
            }
          ]
        },
        {
          "scopes": ["team", "groupChat"],
          "commands": [
            {
              "title": "summary",
              "description": "Get a summary of account activity"
            },
            {
              "title": "help",
              "description": "Get help with available commands"
            }
          ]
        }
      ]
    }
  ],
  "copilotAgents": {
    "customEngineAgents": [
      {
        "id": "{{BOT_ID}}",
        "type": "bot",
        "disclaimer": {
          "text": "This banking assistant uses AI to help with your financial queries. Always verify important financial information before making decisions. Sensitive actions require your explicit approval."
        }
      }
    ]
  },
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "*.azurewebsites.net",
    "*.ngrok-free.app",
    "token.botframework.com"
  ],
  "defaultInstallScope": "personal"
}
